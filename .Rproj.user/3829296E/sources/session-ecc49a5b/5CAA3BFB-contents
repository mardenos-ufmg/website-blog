library(httr)
library(jsonlite)

# URL da pasta no GitHub via API
url_api <- "https://api.github.com/repos/mardenos-ufmg/website-blog/contents/posts"

# Pasta local onde você quer salvar
dest_dir <- paste0(tempdir(), "posts")
dir.create(dest_dir, recursive = TRUE, showWarnings = FALSE)

# Pega a lista de arquivos
res <- GET(url_api)
stop_for_status(res)
files <- fromJSON(content(res, as = "text"))

# Baixa cada arquivo
for (f in files$name) {
  download_url <- files$download_url[files$name == f]
  dest_file <- file.path(dest_dir, f)
  download.file(download_url, dest_file, quiet = FALSE)
  message("Baixado: ", f)
}